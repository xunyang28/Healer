<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Healer</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        background: #0f0f1a;
        color: #e2e8f0;
        text-align: center;
        padding: 80px 20px;
      }

      h1 { font-size: 2.5rem; color: #7c6af7; margin-bottom: 12px; }
